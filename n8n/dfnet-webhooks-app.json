      "parameters": { "jsCode": "\nconst d = $json;\nconst titulos = d.titulos || d.titulosAbertos || [];\nconst boletos = titulos.map(t => ({\n  mes: t.competencia || t.dataVencimento || t.data_vencimento || '\\u2014',\n  valor: t.valor || '0,00',\n  venc: t.dataVencimento || t.data_vencimento || '\\u2014',\n  status: 'aberto',\n  linha: t.linhaDigitavel || t.codigoBarras || t.codigo_barras || '',\n  link: t.link || t.link_cobranca || ''\n}));\nreturn [{ json: { boletos } }];" },
