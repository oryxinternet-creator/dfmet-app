    {
      "parameters": { "jsCode": "const d = $json;\nconst root = Array.isArray(d) ? d[0] : d;\nconst contratos = (root && root.contratos) || [];\nif (!contratos.length) return [{ json: { ok: false, motivo: 'nao_encontrado' } }];\n\nconst senhaDigitada = String($('Webhook app-login').first().json.body.senha || '').trim();\nconst senhaReal = String(contratos[0].contratoCentralSenha || '').trim();\n\nif (!senhaDigitada || senhaDigitada !== senhaReal) {\n  return [{ json: { ok: false, motivo: 'senha_incorreta' } }];\n}\n\nconst title = s => (s || '').toLowerCase().split(' ')\n  .map(p => p.charAt(0).toUpperCase() + p.slice(1)).join(' ');\n\nconst lista = contratos.map(c => {\n  const titulos = c.contratoTitulosAReceber || 0;\n  const aberto = c.contratoValorAberto;\n\n  const ass = Array.isArray(c.assinaturaEletronica) ? c.assinaturaEletronica[0] : (c.assinaturaEletronica || null);\n  let termoUrl = '', termoPdf = '', termoAssinado = false, termoStatus = '';\n  if (ass) {\n    termoUrl = (ass.cliente && ass.cliente.url_assinatura) || '';\n    termoPdf = (ass.documento && ass.documento.url_original) || '';\n    termoStatus = ass.status_atual || '';\n    const dataAss = (ass.cliente && ass.cliente.data_assinatura) || '';\n    termoAssinado = !!dataAss || /assinad|conclu|finaliz/i.test(termoStatus);\n  }\n\n  return {\n    contratoId: c.contratoId || null,\n    clienteId: c.clienteId || null,\n    plano: c.servico_plano || c.planointernet || 'Internet',\n    status: c.contratoStatusDisplay || 'Ativo',\n    vencimento: c.cobVencimento || null,\n    titulos: titulos,\n    valorAberto: (aberto != null) ? Number(aberto).toFixed(2).replace('.', ',') : null,\n    pendencia: titulos > 0,\n    cidade: c.endereco_cidade || '',\n    termoUrl, termoPdf, termoAssinado, termoStatus\n  };\n});\n\nreturn [{ json: {\n  ok: true,\n  nome: title(contratos[0].razaoSocial || 'Cliente'),\n  contratos: lista\n}}];" },
