      "parameters": { "jsCode": "const norm = s => (s==null?'':s).toString().trim().toLowerCase();\nconst ativos = ['sim','true','1','x','ativo','verdadeiro'];\nconst rows = $input.all().map(i => i.json);\nconst promocoes = rows\n  .filter(r => ativos.includes(norm(r.ativo)))\n  .sort((a,b) => (Number(a.ordem)||999) - (Number(b.ordem)||999))\n  .map(r => ({\n    titulo: (r.titulo||'').toString(),\n    texto: (r.texto||'').toString(),\n    cor: (r.cor||'#1b1918').toString(),\n    imagem: (r.imagem||'').toString(),\n    link: (r.link||'').toString(),\n    botao: (r.botao||'Saiba mais').toString()\n  }));\nreturn [{ json: { promocoes } }];" },
