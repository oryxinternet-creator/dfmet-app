      "type": "n8n-nodes-base.googleSheets", "typeVersion": 4.5, "position": [112, -320],
      "credentials": { "googleApi": { "id": "TROCAR_CRED_GOOGLE_DFNET", "name": "PLANILHA GOOGLE DFNET" } }
    },
    {
      "parameters": { "jsCode": "\n// remove tokens vazios e duplicados\nconst seen=new Set(); const out=[];\nfor(const it of items){\n  const t=String(it.json.token||'').trim();\n  if(t && !seen.has(t)){ seen.add(t); out.push({json:{token:t}}); }\n}\nif(!out.length) return [{json:{aviso:'nenhum token na planilha'}}];\nreturn out;" },
      "id": "082c11ce-9ebe-4d09-a427-4bc9092d736a", "name": "Prepara Lista",
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [352, -320]
    },
