        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ message: { token: $json.token, notification: { title: $('Formulário Aviso').first().json.titulo, body: $('Formulário Aviso').first().json.mensagem } } }) }}",
        "options": {}
      },
