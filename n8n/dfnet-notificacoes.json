    {
      "parameters": { "mode": "combine", "combineBy": "combineByPosition", "options": {} },
      "id": "aa3c7414-743c-4c35-8e06-2c05869c9908", "name": "Junta cliente + status",
      "type": "n8n-nodes-base.merge", "typeVersion": 3, "position": [464, 336]
    },
    {
      "parameters": { "jsCode": "\nconst out=[];\nfor(const item of items){\n  const j=item.json;\n  const token=j.token||''; const contrato=String(j.contrato||'');\n  const anterior=String(j.ultimo_status||'').trim().toLowerCase();\n  const contratos=(j.contratos)||[];\n  let atualRaw='';\n  if(Array.isArray(contratos)&&contratos.length){\n    const c=contratos.find(x=>String(x.contratoId)===contrato)||contratos[0];\n    atualRaw=c.contratoStatusDisplay||c.contratoStatus||'';\n  }\n  const atual=String(atualRaw).trim();\n  const atualLow=atual.toLowerCase();\n  const estaBloqueado=atualLow && atualLow!=='ativo';\n  const eraAtivo=anterior===''||anterior==='ativo';\n  const deveNotificar=estaBloqueado && eraAtivo && anterior!==atualLow;\n  out.push({json:{token, contrato, status_atual:atual, notificar:deveNotificar}});\n}\nreturn out;" },
