      "id": "edeaa2cd-1e64-435c-b6a9-c1847b489533", "name": "Lê Clientes (tokens)",
      "type": "n8n-nodes-base.googleSheets", "typeVersion": 4.5, "position": [-96, -32],
      "credentials": { "googleApi": { "id": "TROCAR_CRED_GOOGLE_DFNET", "name": "PLANILHA GOOGLE DFNET" } }
    },
    {
      "parameters": { "jsCode": "\n// Normaliza CPF/CNPJ: remove não-dígitos e completa zeros à esquerda\nconst out=[];\nfor(const item of items){\n  const j={...item.json};\n  let doc=String(j.cpf||'').replace(/\\D/g,'');\n  if(doc.length>0 && doc.length<=11) doc=doc.padStart(11,'0');\n  else if(doc.length>11 && doc.length<14) doc=doc.padStart(14,'0');\n  j.cpf_norm=doc;\n  out.push({json:j});\n}\nreturn out;" },
      "id": "bab17218-fded-45f7-81a0-32b67e1c227f", "name": "Normaliza CPF",
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [128, -32]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://dfnet.sgp.net.br/api/central/titulos/",
        "sendBody": true, "contentType": "form-urlencoded",
        "bodyParameters": { "parameters": [
          { "name": "token", "value": "TROCAR_TOKEN_SGP_DFNET" },
          { "name": "app", "value": "whatsApp" },
          { "name": "cpfcnpj", "value": "={{ $json.cpf_norm }}" },
          { "name": "status", "value": "1" },
          { "name": "limit", "value": "50" }
        ] }, "options": {}
      },
      "id": "ec0413e7-219a-43c8-adb1-b4380f3c0021", "name": "Títulos do Cliente",
      "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [352, -32], "onError": "continueRegularOutput"
    },
    {
      "parameters": { "mode": "combine", "combineBy": "combineByPosition", "options": {} },
      "id": "d9c7af84-22f1-4fd1-ac1c-42fe1ee330d2", "name": "Junta cliente + faturas",
      "type": "n8n-nodes-base.merge", "typeVersion": 3, "position": [560, -32]
    },
    {
      "parameters": { "jsCode": "\nconst amanha=new Date(); amanha.setDate(amanha.getDate()+1);\nconst alvo=amanha.toISOString().slice(0,10);\nconst out=[];\nfor(const item of items){\n  const j=item.json; const token=j.token||''; const faturas=(j.faturas)||[];\n  if(!token||!Array.isArray(faturas)) continue;\n  const vence=faturas.find(f=>String(f.vencimento||f.vencimento_atualizado||'').slice(0,10)===alvo);\n  if(vence){\n    const valor=Number(vence.valorcorrigido||vence.valor||0).toFixed(2).replace('.',',');\n    out.push({json:{token, valor, venc:alvo}});\n  }\n}\nreturn out;" },
      "id": "8d50c670-d9c1-47ca-8fee-8f1a3a9a7b09", "name": "Quem vence amanhã",
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [784, -32]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://fcm.googleapis.com/v1/projects/TROCAR_PROJETO_FIREBASE_DFNET/messages:send",
        "authentication": "predefinedCredentialType", "nodeCredentialType": "googleApi",
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ message: { token: $json.token, notification: { title: 'Sua fatura vence amanhã 💳', body: 'Fatura de R$ '+$json.valor+' vence amanhã. Toque para ver a 2ª via.' } } }) }}",
        "options": {}
      },
